{
  "$schema": "https://opencode.ai/config.json",

  // Optional project-local RiftReader OpenCode template.
  // Copy this file to .opencode/opencode.local.jsonc or merge the pieces you
  // want into your user-level OpenCode config. Do not put provider keys,
  // Context7 keys, GitHub tokens, or other secrets in this tracked template.
  "instructions": [
    "./agents.md",
    "./docs/workflow/non-codex-desktop-chatgpt-workflow.md",
    "./docs/workflow/opencode-non-codex-bridge.md"
  ],
  // Keep the repo-local template explicit so CLI wrappers do not depend on a
  // stale or incompatible user/default model. Override locally if this model is
  // not visible in `opencode models openai`.
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5-fast",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "default_agent": "riftreader-readonly",
  "share": "manual",
  "autoupdate": "notify",
  "tool_output": {
    "max_lines": 1200,
    "max_bytes": 50000
  },
  "permission": {
    "edit": "deny",
    "bash": {
      "*": "ask",
      "git --no-pager status *": "allow",
      "git --no-pager log *": "allow",
      "git --no-pager for-each-ref *": "allow",
      "git --no-pager diff --check *": "allow",
      "python .\\scripts\\coordinate_recovery_status.py --json": "allow",
      "python .\\scripts\\validate_current_truth.py --json": "allow",
      "python .\\tools\\riftreader_workflow\\status_packet.py *": "allow",
      "python .\\tools\\riftreader_workflow\\live_test_triage.py *": "allow",
      "python .\\tools\\riftreader_workflow\\opencode_bridge.py *": "allow",
      "python .\\tools\\riftreader_workflow\\apply_package.py *": "ask",
      ".\\scripts\\riftreader-workflow-status.cmd *": "allow",
      ".\\scripts\\riftreader-live-triage.cmd *": "allow",
      ".\\scripts\\riftreader-opencode-prompt.cmd *": "allow",
      ".\\scripts\\riftreader-opencode-integration.cmd *": "allow",
      ".\\scripts\\riftreader-operator-lite.cmd --self-test *": "allow",
      ".\\scripts\\riftreader-package-intake-selftest.cmd *": "allow",
      ".\\scripts\\riftreader-package-intake.cmd *": "ask",
      "opencode --version": "allow",
      "opencode models *": "allow",
      "cmd /d /c opencode --version": "allow",
      "cmd /d /c opencode models *": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "cheatengine*": "deny",
      "*cheatengine-exec.ps1*": "deny",
      "*x64dbg*": "ask",
      "*send-rift-key*": "deny",
      "*post-rift-key*": "deny"
    }
  },
  "agent": {
    "riftreader-readonly": {
      "description": "Read-only RiftReader scout for non-Codex desktop ChatGPT handoffs and status packets.",
      "mode": "primary",
      "prompt": "You are the RiftReader read-only OpenCode bridge. For wrapper-driven runs, follow the adaptive prompt generated by tools/riftreader_workflow/opencode_bridge.py and rerun its required status commands before final output. For interactive runs, first run .\\scripts\\riftreader-workflow-status.cmd --compact-json --write, treat the newest command output as current truth, and adapt to blockers such as dirty worktree, model/provider mismatch, no-live-process, artifact-pid-stale, or movement gate closed. Report blockers before recommendations. Do not edit files, stage, commit, push, send live input, run movement, /reloadui, screenshot hotkeys, attach CE/x64dbg, promote stale proof, or write provider repos.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git --no-pager status *": "allow",
          "git --no-pager log *": "allow",
          "git --no-pager for-each-ref *": "allow",
          "python .\\scripts\\coordinate_recovery_status.py --json": "allow",
          "python .\\tools\\riftreader_workflow\\status_packet.py *": "allow",
          "python .\\tools\\riftreader_workflow\\live_test_triage.py *": "allow",
          "python .\\tools\\riftreader_workflow\\opencode_bridge.py *": "allow",
          "python .\\tools\\riftreader_workflow\\apply_package.py *": "ask",
          ".\\scripts\\riftreader-workflow-status.cmd *": "allow",
          ".\\scripts\\riftreader-live-triage.cmd *": "allow",
          ".\\scripts\\riftreader-opencode-prompt.cmd *": "allow",
          ".\\scripts\\riftreader-opencode-integration.cmd *": "allow",
          ".\\scripts\\riftreader-operator-lite.cmd --self-test *": "allow",
          ".\\scripts\\riftreader-package-intake-selftest.cmd *": "allow",
          ".\\scripts\\riftreader-package-intake.cmd *": "ask",
          "opencode --version": "allow",
          "opencode models *": "allow",
          "cmd /d /c opencode --version": "allow",
          "cmd /d /c opencode models *": "allow",
          "git add *": "deny",
          "git commit *": "deny",
          "git push *": "deny",
          "*send-rift-key*": "deny",
          "*post-rift-key*": "deny",
          "*x64dbg*": "deny",
          "*cheatengine*": "deny"
        }
      }
    },
    "riftreader-validator": {
      "description": "Runs bounded local validation without editing or publishing.",
      "mode": "primary",
      "prompt": "Run only targeted validation requested by the operator. Summarize exact commands, exit codes, failures, and next safest fix. Treat exit code 2 from RiftReader status/triage helpers as a safe blocker to report, not as permission to bypass gates. Do not edit, stage, commit, push, send input, move, or attach debuggers.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python -m compileall *": "allow",
          "python -m unittest *": "allow",
          "python .\\scripts\\validate_current_truth.py --json": "allow",
          "python .\\scripts\\coordinate_recovery_status.py --json": "allow",
          "dotnet build *": "ask",
          "dotnet test *": "ask",
          "git --no-pager diff --check *": "allow",
          "git add *": "deny",
          "git commit *": "deny",
          "git push *": "deny"
        }
      }
    },
    "riftreader-applier": {
      "description": "Inspects desktop ChatGPT packages by default and applies only when explicitly approved.",
      "mode": "primary",
      "prompt": "Default to package inspection only: run .\\scripts\\riftreader-package-intake.cmd --package <path> --compact-json and summarize changed files, blockers, warnings, errors, diff path, and safety flags. Use --apply only after explicit operator approval in the current turn. Verify allowlisted target paths, backups, summaries, and diffs. Do not stage, commit, push, send live input, run movement, attach debuggers, or write provider repos.",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git --no-pager status *": "allow",
          "git --no-pager diff *": "allow",
          "git --no-pager diff --check *": "allow",
          "python *": "ask",
          ".\\scripts\\riftreader-package-intake-selftest.cmd *": "allow",
          ".\\scripts\\riftreader-package-intake.cmd *": "ask",
          "git add *": "deny",
          "git commit *": "deny",
          "git push *": "deny"
        }
      }
    },
    "riftreader-integration": {
      "description": "Autonomous patch-and-test lane for RiftReader OpenCode integration only.",
      "mode": "primary",
      "prompt": "Continue RiftReader OpenCode integration through small validated milestones. For wrapper-driven runs, treat the generated lanePolicy as authoritative: integration may edit only OpenCode bridge code, wrappers, tests, workflow docs, and the example OpenCode config; non-integration lanes remain read-only. After each passing milestone, choose the next safe in-scope improvement instead of stopping. Run targeted compile/unit validation, wrapper self-test when prompt/policy behavior changes, and git diff --check before declaring a milestone complete. Stop only for a hard blocker, out-of-scope work, live/proof risk, or Git mutation request. Do not send live input, move, /reloadui, attach CE/x64dbg, stage, commit, push, or write provider repos.",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git --no-pager status *": "allow",
          "git --no-pager diff --check *": "allow",
          "python -m compileall tools\\riftreader_workflow *": "allow",
          "python -m unittest scripts.test_opencode_bridge *": "allow",
          "python -m unittest scripts.test_opencode_status_packet *": "allow",
          "python -m unittest scripts.test_opencode_bridge scripts.test_opencode_status_packet *": "allow",
          "python .\\tools\\riftreader_workflow\\status_packet.py *": "allow",
          "python .\\tools\\riftreader_workflow\\opencode_bridge.py *": "allow",
          ".\\scripts\\riftreader-workflow-status.cmd --compact-json *": "allow",
          ".\\scripts\\riftreader-opencode-prompt.cmd *": "allow",
          "git add *": "deny",
          "git commit *": "deny",
          "git push *": "deny",
          "*send-rift-key*": "deny",
          "*post-rift-key*": "deny",
          "*x64dbg*": "deny",
          "*cheatengine*": "deny"
        }
      }
    },
    "riftreader-handoff-scribe": {
      "description": "Creates explicit, approved handoff/status docs only.",
      "mode": "primary",
      "prompt": "Write only explicitly requested handoff/status documentation and keep historical/stale truth separate from current proof. Never edit provider repos, send input, attach debuggers, stage, commit, or push.",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git --no-pager status *": "allow",
          "git --no-pager diff *": "allow",
          "python .\\scripts\\validate_current_truth.py --json": "allow",
          "git add *": "deny",
          "git commit *": "deny",
          "git push *": "deny"
        }
      }
    },
    "riftreader-live-observer": {
      "description": "No-input live observer for process/window/status checks after RIFT is loaded.",
      "mode": "primary",
      "prompt": "Observe only. Run .\\scripts\\riftreader-live-triage.cmd --json --write and .\\scripts\\riftreader-workflow-status.cmd --compact-json --write to discover/report PID/HWND/status gates that do not send input. If liveTarget is artifact-pid-stale, state that a rift_x64 process is visible but the proof artifact is historical; process visibility is not same-target or in-world proof, and movement remains blocked. Do not move, send keys, click, /reloadui, screenshot hotkeys, attach CE/x64dbg, promote stale proof, edit files, stage, commit, or push.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python .\\scripts\\coordinate_recovery_status.py --json": "allow",
          "python .\\tools\\riftreader_workflow\\status_packet.py *": "allow",
          "python .\\tools\\riftreader_workflow\\live_test_triage.py *": "allow",
          "python .\\tools\\riftreader_workflow\\opencode_bridge.py *": "allow",
          ".\\scripts\\riftreader-workflow-status.cmd *": "allow",
          ".\\scripts\\riftreader-live-triage.cmd *": "allow",
          ".\\scripts\\riftreader-opencode-prompt.cmd *": "allow",
          ".\\scripts\\riftreader-opencode-integration.cmd *": "allow",
          "*send-rift-key*": "deny",
          "*post-rift-key*": "deny",
          "*x64dbg*": "deny",
          "*cheatengine*": "deny",
          "git add *": "deny",
          "git commit *": "deny",
          "git push *": "deny"
        }
      }
    }
  }
}
