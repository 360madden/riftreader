{
  "version": "riftreader-drive-inbox-contract-v0.1.0",
  "total_character_count": "1010",
  "purpose": "Machine-readable contract for using Google Drive as RiftReader artifact transport, archive, inbox, handoff, and status storage.",
  "drive_root_default": "G:\\My Drive\\RiftReader",
  "repo_root_default": "C:\\RIFT MODDING\\RiftReader",
